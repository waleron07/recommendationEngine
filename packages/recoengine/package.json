{
  "name": "recoengine",
  "version": "0.1.0",
  "description": "Algorithmic, explainable recommendation engine — batteries-included meta package. Re-exports @recoengine/core plus the default strategy, feature, modifier and diversity plugins.",
  "keywords": [
    "recommendation",
    "recommender",
    "ranking",
    "scoring",
    "explainable",
    "personalization"
  ],
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --build"
  },
  "dependencies": {
    "@recoengine/core": "workspace:*",
    "@recoengine/diversity": "workspace:*",
    "@recoengine/features": "workspace:*",
    "@recoengine/modifiers": "workspace:*",
    "@recoengine/strategies": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  }
}
